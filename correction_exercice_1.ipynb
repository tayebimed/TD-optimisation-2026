# 📌 Correction de l'exercice 1

---

## 1. Définition des fonctions

```python
import sympy as sp
from IPython.display import display, Math

# Variable symbolique
x = sp.symbols('x', real=True)

# Fonctions
f = 2*x**2 - 3
g = x**3 - 3*x**2 + 2
h = x**5 + 4*x**3 + 4*x

print("📌 Les trois fonctions sont :\n")

display(Math(r"f(x) = " + sp.latex(f)))
display(Math(r"g(x) = " + sp.latex(g)))
display(Math(r"h(x) = " + sp.latex(h)))
```

---

## 2. Dérivée de f

```python
df = sp.diff(f, x)
display(Math(r"f'(x) = " + sp.latex(df)))
```

---

## 3. Développement limité de f autour de 0

```python
DL_f = sp.series(f, x, 0, 4)
display(DL_f)
```

---

## 4. Tracé des courbes f et g

```python
import numpy as np
import matplotlib.pyplot as plt

X = np.linspace(-3, 3, 400)

Yf = 2*X**2 - 3
Yg = X**3 - 3*X**2 + 2

plt.plot(X, Yf, label='f(x)')
plt.plot(X, Yg, label='g(x)')

plt.xlabel('x')
plt.ylabel('y')
plt.title('Courbes de f et g')

plt.legend()
plt.grid(True)
plt.show()
```

---

## 5. Points particuliers de g(x)

```python
g = x**3 - 3*x**2 + 2

X = np.linspace(-3, 3, 400)
Yg = X**3 - 3*X**2 + 2

plt.plot(X, Yg, label='g(x)')

y0 = float(g.subs(x, 0))
y2 = float(g.subs(x, 2))

plt.scatter([0, 2], [y0, y2], color='red')

plt.text(0, y0, '(0, g(0))')
plt.text(2, y2, '(2, g(2))')

plt.xlabel('x')
plt.ylabel('y')
plt.title('Points particuliers sur g(x)')
plt.grid(True)
plt.legend()
plt.show()
```

---

## 6. Étude de la dérivée de h

```python
h = x**5 + 4*x**3 + 4*x

dh = sp.diff(h, x)
dh_factored = sp.factor(dh)

display(Math(r"h'(x) = " + sp.latex(dh_factored)))
```

---

## 7. Tracé de h'(x)

```python
x = sp.symbols('x', real=True)

h = x**5 + 4*x**3 + 4*x
dh = sp.diff(h, x)

X = np.linspace(-3, 3, 400)

f_dh = sp.lambdify(x, dh, 'numpy')
Ydh = f_dh(X)

plt.plot(X, Ydh)

plt.xlabel('x')
plt.ylabel("h'(x)")
plt.title("Dérivée de h(x)")
plt.grid(True)
plt.show()
```
